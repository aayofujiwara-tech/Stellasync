{
  "name": "stellasync",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "seed": "ts-node --project tsconfig.scripts.json scripts/seedTestData.ts",
    "seed:admin": "ts-node --project tsconfig.scripts.json scripts/seedAdminRole.ts",
    "seed:demo": "ts-node --project tsconfig.scripts.json scripts/seedDemoData.ts",
    "seed:store": "ts-node --project tsconfig.scripts.json scripts/seedTestStore.ts",
    "teardown:demo": "ts-node --project tsconfig.scripts.json scripts/teardownDemoData.ts",
    "teardown:store": "ts-node --project tsconfig.scripts.json scripts/teardownTestStore.ts",
    "test:rules": "firebase emulators:exec --only firestore --project demo-test \"vitest run --config vitest.rules.config.ts\""
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "firebase": "^10.14.1",
    "firebase-admin": "^12.0.0",
    "lucide-react": "^0.462.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
